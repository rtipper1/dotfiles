theme = Everforest Dark Hard

font-family = JetBrainsMonoNL Nerd Font

font-size=13
font-thicken=true
font-thicken-strength = 1
adjust-cell-height = 1

background-opacity = 0.65
background-blur=true

fullscreen = false

window-padding-x = 10
window-padding-y = 5

copy-on-select = true

mouse-hide-while-typing=true
